# FanPad Service Health Monitor — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ── Database (used by docker-compose) ────────────────────────────────────────

POSTGRES_USER=fanpad
POSTGRES_PASSWORD=fanpad_dev
POSTGRES_DB=fanpad_health

# ── Optional: Messaging Service Credentials (for production probes) ───────────
# Leave blank to use simulation mode only

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=sandbox.mailgun.org
MAILGUN_TEST_RECIPIENT=health@yourdomain.com

# AWS SES
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SES_TEST_RECIPIENT=health@yourdomain.com

# Twilio (use magic test numbers for sandbox — no real SMS sent)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_TEST_FROM=+15005550001
TWILIO_TEST_TO=+15005550006

# ── Local dev defaults (match docker-compose) ────────────────────────────────

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
